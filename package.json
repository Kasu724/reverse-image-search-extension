{
  "name": "imagelab",
  "version": "1.0.0",
  "private": true,
  "description": "Combined Chromium extension for right-click image conversion and reverse image search.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:extension": "pnpm --filter @imagelab/extension dev",
    "build": "pnpm --filter @imagelab/extension build",
    "typecheck": "pnpm --filter @imagelab/extension typecheck",
    "test": "pnpm --filter @imagelab/extension test",
    "test:api": "cd apps/api && python -m pytest"
  }
}
